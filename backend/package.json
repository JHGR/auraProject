{
  "name": "supercopias-backend",
  "version": "0.1.0",
  "description": "API REST minimal para Super Copias (desarrollo)",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:prod": "NODE_ENV=production node index.js",
    "dev": "nodemon index.js",
    "dev:clean": "nodemon --exec \"node index.js\" --ignore db.json --ignore uploads/",
    "migrate": "node scripts/migrate-to-postgres.js",
    "setup-db": "psql -U postgres -d supercopias -f BD_SUPERCOPIAS.sql",
    "build": "echo 'No build step needed for Node.js backend'"
  },
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "lowdb": "1.0.0",
    "multer": "^1.4.4",
    "nanoid": "^3.3.7",
    "pdfkit": "^0.18.0",
    "pg": "^8.11.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=18.0.0 <19.0.0",
    "npm": ">=9.0.0"
  }
}
