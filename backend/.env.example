# =====================================================
# Configuración SuperCopias Backend
# =====================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env en la misma carpeta
# 2. Ajusta los valores según tu entorno (DEV o QA)
# 3. NUNCA subas el archivo .env a Git
# =====================================================

# =====================================================
# BASE DE DATOS POSTGRESQL
# =====================================================

# --- DESARROLLO LOCAL ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=admin
DB_NAME=supercopias

# --- QA/PRODUCCIÓN (Railway/Render) ---
# En producción, usa DATABASE_URL en lugar de las variables individuales
# DATABASE_URL se configura automáticamente en Railway
# DATABASE_URL=postgresql://usuario:password@host:puerto/database

# Pool de Conexiones
DB_CONNECTION_LIMIT=10
DB_TIMEOUT=60000
DB_ACQUIRE_TIMEOUT=60000

# =====================================================
# SEGURIDAD - JWT
# =====================================================
# ⚠️ IMPORTANTE: Cambia este secret en producción
JWT_SECRET=tu_clave_secreta_muy_segura_aqui_2024

# =====================================================
# SERVIDOR
# =====================================================
PORT=3000

# Entorno: development | production
NODE_ENV=development

# =====================================================
# ARCHIVOS Y UPLOADS
# =====================================================
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# =====================================================
# LOGS
# =====================================================
# Niveles: error | warn | info | debug
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# =====================================================
# SESIÓN
# =====================================================
SESSION_TIMEOUT=86400000

# =====================================================
# CORS - FRONTEND URLs
# =====================================================

# --- DESARROLLO LOCAL ---
FRONTEND_URL=http://localhost:4200
ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- QA/PRODUCCIÓN ---
# Descomentar y configurar para producción:
# FRONTEND_URL=https://tu-app-frontend.up.railway.app
# ALLOWED_ORIGINS=https://tu-app-frontend.up.railway.app,https://tu-dominio.com

# =====================================================
# NOTAS IMPORTANTES
# =====================================================
# 
# DESARROLLO LOCAL:
# - Usa las variables DB_HOST, DB_USER, etc.
# - NODE_ENV=development
# - No configures DATABASE_URL
#
# QA/PRODUCCIÓN (Railway):
# - Railway configura DATABASE_URL automáticamente
# - NODE_ENV=production
# - Configura FRONTEND_URL con la URL de Railway
# - Las variables DB_HOST, DB_USER se ignoran si existe DATABASE_URL
#
# Ver: backend/config/database.js para lógica de conexión
# =====================================================