# Configuración para servidores Apache
# Redirigir todas las rutas no encontradas a index.html para SPA
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Handle Angular routes
    # Si el archivo o directorio no existe, redirigir a index.html
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^.*$ /index.html [QSA,L]
</IfModule>

# Configuración de headers para mejor performance
<IfModule mod_headers.c>
    # Cache control para archivos estáticos
    <FilesMatch "\.(css|js|png|jpg|jpeg|gif|ico|svg)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
    
    # No cache para index.html
    <FilesMatch "index\.html$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
</IfModule>